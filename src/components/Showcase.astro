---
// Showcase.astro — real app screenshots with info beside each
const shots = [
  {
    img: "/screens/home.jpg",
    tag: "Home Screen",
    title: "A home screen you already know",
    body: "Open the app and you're home. A featured banner, Trending rows, Movies and Series — plus quick language tabs for Hindi, Tamil, Telugu and more, all one click away on the sidebar.",
  },
  {
    img: "/screens/library.jpg",
    tag: "Library",
    title: "A library that keeps growing",
    body: "Thousands of movies and series in clean poster rows — Hollywood, Bollywood, regional and the latest OTT drops. Everything is organised so you find something to watch in seconds.",
  },
  {
    img: "/screens/detail.jpg",
    tag: "Title Details",
    title: "Everything you need before you press play",
    body: "Ratings, release year, number of seasons, genres and a full synopsis on every title. Jump straight to S1 E1 or add it to My List for later.",
  },
  {
    img: "/screens/servers.jpg",
    tag: "Servers",
    title: "Multiple servers, minimal buffering",
    body: "Every title runs on more than one high-speed server. If one slows down during peak hours, switch to another with your remote — playback stays smooth.",
  },
  {
    img: "/screens/quality.jpg",
    tag: "Quality",
    title: "Your quality, your call",
    body: "Pick 480p, 720p or 1080p, or let Auto adapt to your connection. Data Saver caps the bitrate when you're on limited data — full control from Settings.",
  },
  {
    img: "/screens/audio.jpg",
    tag: "Audio & Subtitles",
    title: "Watch in your language",
    body: "Multi-language audio is built in — Hindi, English, Tamil, Telugu, Spanish, French and more. Set your preferred track once and every title respects it.",
  },
];
---

<section id="screens" class="bg-ink py-20 sm:py-24">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <p class="text-sm font-semibold uppercase tracking-widest text-neon">Inside the App</p>
    <h2 class="mt-3 max-w-2xl text-3xl font-extrabold tracking-tight sm:text-4xl">
      See NetMirror TV in action
    </h2>
    <p class="mt-4 max-w-2xl text-base leading-relaxed text-muted sm:text-lg">
      Real screens from the app on a TV — exactly what you'll see on your Android TV, Firestick or Smart TV.
    </p>

    <div class="mt-16 space-y-16 sm:space-y-20">
      {shots.map((s, i) => (
        <div class={`flex flex-col gap-8 lg:flex-row lg:items-center lg:gap-14 ${i % 2 === 1 ? "lg:flex-row-reverse" : ""}`}>
          <!-- screenshot -->
          <div class="lg:w-3/5">
            <div class="overflow-hidden rounded-2xl border border-line bg-ink-2 p-2 shadow-2xl">
              <img
                src={s.img}
                alt={`NetMirror TV — ${s.title}`}
                loading="lazy"
                width="1280"
                height="720"
                class="w-full rounded-xl"
              />
            </div>
          </div>
          <!-- info -->
          <div class="lg:w-2/5">
            <span class="inline-block rounded-full border border-line bg-ink-2 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-neon">
              {s.tag}
            </span>
            <h3 class="mt-4 text-2xl font-bold leading-snug text-fg sm:text-3xl">{s.title}</h3>
            <p class="mt-4 text-base leading-relaxed text-muted">{s.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
