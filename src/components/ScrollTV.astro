---
// ScrollTV.astro — scroll-driven TV showcase (sticky stage, screens cross-fade on scroll)
const steps = [
  {
    img: "/screens/home.jpg",
    tag: "Home",
    title: "Open to a home you already know",
    body: "A featured banner, Trending rows and quick language tabs — Hindi, Tamil, Telugu and more, one click away.",
  },
  {
    img: "/screens/library.jpg",
    tag: "Library",
    title: "Browse a library that keeps growing",
    body: "Thousands of movies and series in clean poster rows — Hollywood, Bollywood, regional and the latest OTT drops.",
  },
  {
    img: "/screens/detail.jpg",
    tag: "Details",
    title: "Know everything before you press play",
    body: "Ratings, seasons, genres and a full synopsis on every title. Jump to S1 E1 or save it to My List.",
  },
  {
    img: "/screens/servers.jpg",
    tag: "Servers",
    title: "Switch servers, skip the buffering",
    body: "Every title runs on multiple high-speed servers. If one slows down, change it with your remote — instantly.",
  },
  {
    img: "/screens/audio.jpg",
    tag: "Audio",
    title: "Watch in your own language",
    body: "Built-in multi-language audio — Hindi, English, Tamil, Telugu, Spanish, French and more. Set it once.",
  },
];
---

<section
  id="scroll-tv"
  class="relative bg-ink"
  style={`height: ${steps.length * 62 + 80}vh;`}
  data-steps={steps.length}
>
  <!-- Scroll sentinels (one band per screen; the one crossing viewport-center is active) -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0">
    {steps.map((_, i) => (
      <div
        data-step={i}
        class="absolute left-0 w-px"
        style={`top: ${(i / steps.length) * 100}%; height: ${100 / steps.length}%;`}
      ></div>
    ))}
  </div>

  <!-- Sticky stage -->
  <div class="sticky top-0 flex h-screen items-center overflow-hidden">
    <!-- ambient glow -->
    <div aria-hidden="true" class="pointer-events-none absolute left-1/2 top-1/2 h-[34rem] w-[34rem] -translate-x-1/2 -translate-y-1/2 rounded-full bg-neon/10 blur-[130px]"></div>

    <div class="relative mx-auto grid w-full max-w-6xl gap-8 px-5 sm:px-8 lg:grid-cols-[1.4fr_1fr] lg:items-center lg:gap-14">
      <!-- section label (top-left) -->
      <p class="absolute -top-2 left-5 text-sm font-semibold uppercase tracking-widest text-neon sm:left-8 lg:hidden">
        See it in action
      </p>

      <!-- TV -->
      <div class="mx-auto w-full max-w-2xl">
        <div class="rounded-[1.4rem] border border-line bg-gradient-to-b from-ink-3 to-ink p-2.5 shadow-2xl sm:p-3">
          <div class="relative aspect-video overflow-hidden rounded-xl bg-black">
            {steps.map((s, i) => (
              <img
                src={s.img}
                alt={`NetMirror TV — ${s.title}`}
                loading={i === 0 ? "eager" : "lazy"}
                width="1280"
                height="720"
                data-screen={i}
                class={`absolute inset-0 h-full w-full object-cover transition-opacity duration-500 ${i === 0 ? "opacity-100" : "opacity-0"}`}
              />
            ))}
          </div>
        </div>
        <!-- TV stand -->
        <div class="mx-auto mt-0 h-5 w-px bg-line"></div>
        <div class="mx-auto h-1.5 w-40 rounded-full bg-line"></div>
      </div>

      <!-- Captions + progress -->
      <div class="lg:pr-4">
        <p class="hidden text-sm font-semibold uppercase tracking-widest text-neon lg:block">
          See it in action
        </p>

        <!-- stacked caption blocks -->
        <div class="relative mt-4 min-h-[150px] sm:min-h-[170px]">
          {steps.map((s, i) => (
            <div
              data-caption={i}
              class={`absolute inset-0 transition-all duration-500 ${i === 0 ? "opacity-100 translate-y-0" : "pointer-events-none translate-y-3 opacity-0"}`}
            >
              <span class="inline-block rounded-full border border-line bg-ink-2 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-neon">
                {s.tag}
              </span>
              <h3 class="mt-3 text-2xl font-bold leading-snug text-fg sm:text-3xl">{s.title}</h3>
              <p class="mt-3 text-base leading-relaxed text-muted">{s.body}</p>
            </div>
          ))}
        </div>

        <!-- progress dots -->
        <div class="mt-6 flex items-center gap-2" role="tablist" aria-label="App screens">
          {steps.map((_, i) => (
            <button
              type="button"
              data-dot={i}
              aria-label={`Go to screen ${i + 1}`}
              class={`h-2 rounded-full transition-all duration-300 ${i === 0 ? "w-7 bg-neon" : "w-2 bg-line hover:bg-muted"}`}
            ></button>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initScrollTV() {
    const section = document.getElementById("scroll-tv");
    if (!section) return;
    const n = Number(section.getAttribute("data-steps")) || 0;
    const screens = section.querySelectorAll("[data-screen]");
    const captions = section.querySelectorAll("[data-caption]");
    const dots = section.querySelectorAll("[data-dot]");
    if (!screens.length) return;

    let current = -1;

    function setActive(i) {
      if (i === current) return;
      current = i;
      screens.forEach((el, k) => {
        el.classList.toggle("opacity-100", k === i);
        el.classList.toggle("opacity-0", k !== i);
      });
      captions.forEach((el, k) => {
        const on = k === i;
        el.classList.toggle("opacity-100", on);
        el.classList.toggle("translate-y-0", on);
        el.classList.toggle("opacity-0", !on);
        el.classList.toggle("translate-y-3", !on);
        el.classList.toggle("pointer-events-none", !on);
      });
      dots.forEach((el, k) => {
        const on = k === i;
        el.classList.toggle("w-7", on);
        el.classList.toggle("bg-neon", on);
        el.classList.toggle("w-2", !on);
        el.classList.toggle("bg-line", !on);
      });
    }

    // Whichever sentinel band is crossing the viewport's vertical center is active.
    const sentinels = section.querySelectorAll("[data-step]");
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) setActive(Number(e.target.getAttribute("data-step")));
        });
      },
      { rootMargin: "-50% 0px -50% 0px", threshold: 0 }
    );
    sentinels.forEach((s) => io.observe(s));

    // click a dot to jump to that screen
    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => {
        const total = section.offsetHeight - window.innerHeight;
        const target = section.offsetTop + ((i + 0.5) / n) * total;
        window.scrollTo({ top: target, behavior: "smooth" });
      });
    });

    setActive(0);
  }

  initScrollTV();
  document.addEventListener("astro:after-swap", initScrollTV);
</script>
