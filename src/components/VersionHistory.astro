---
// VersionHistory.astro — past releases table
const releases = [
  { v: "2.0.8", date: "6 Jun 2026", latest: true, notes: "Beta Server 2, redesigned UI, 8 OTT services, Anime section, Picture-in-Picture, ads removed, optional sign-in." },
  { v: "2.0.0", date: "12 Apr 2026", notes: "Added Sony LIV, Zee5 & MX Player. Bigger library and faster home screen." },
  { v: "1.8.0", date: "20 Feb 2026", notes: "Apple TV+ and JioHotstar added. Improved cross-platform search." },
  { v: "1.5.0", date: "9 Dec 2025", notes: "Performance and stability improvements, subtitle sync fixes." },
  { v: "1.0.0", date: "18 Sep 2025", notes: "Initial release — Netflix & Prime Video in one app." },
];
---

<section id="version-history" class="bg-ink py-20 sm:py-24">
  <div class="mx-auto max-w-4xl px-5 sm:px-8">
    <p class="text-sm font-semibold uppercase tracking-widest text-neon">Version History</p>
    <h2 class="mt-3 text-3xl font-extrabold tracking-tight sm:text-4xl">
      NetMirror TV release history
    </h2>
    <p class="mt-4 max-w-2xl text-base leading-relaxed text-muted sm:text-lg">
      Regular updates every few weeks. Here's how NetMirror TV has grown.
    </p>

    <div class="mt-10 overflow-hidden rounded-2xl border border-line">
      <table class="w-full text-left text-sm">
        <thead>
          <tr class="border-b border-line bg-ink-2 text-xs uppercase tracking-wide text-muted">
            <th class="px-5 py-3 font-semibold">Version</th>
            <th class="px-5 py-3 font-semibold">Date</th>
            <th class="px-5 py-3 font-semibold">Highlights</th>
          </tr>
        </thead>
        <tbody>
          {releases.map((r, i) => (
            <tr class={i % 2 === 1 ? "bg-ink-2/60" : ""}>
              <td class="whitespace-nowrap px-5 py-4 align-top font-bold text-fg">
                {r.v}
                {r.latest && <span class="ml-2 rounded-full bg-neon-3/15 px-2 py-0.5 text-[10px] font-bold uppercase text-neon-3">Latest</span>}
              </td>
              <td class="whitespace-nowrap px-5 py-4 align-top text-muted">{r.date}</td>
              <td class="px-5 py-4 align-top text-muted">{r.notes}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>
