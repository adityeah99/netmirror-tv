---
import { DOWNLOAD_PAGE } from "../config";
// Navbar.astro — sticky top bar + mobile bottom download bar
const links = [
  { href: "#features", label: "Features" },
  { href: "#download", label: "Download" },
  { href: "#review", label: "Reviews" },
  { href: "#faq", label: "FAQ" },
];
---

<header class="sticky top-0 z-50 border-b border-line bg-ink/80 backdrop-blur-md">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-5 py-3 sm:px-8">
    <!-- logo -->
    <a href="#top" class="flex items-center gap-2">
      <img src="/logo.png" alt="NetMirror TV logo" class="h-9 w-9 rounded-lg object-cover" />
      <span class="text-lg font-extrabold tracking-tight text-fg">NetMirror <span class="text-neon">TV</span></span>
    </a>

    <!-- desktop links -->
    <ul class="hidden items-center gap-8 lg:flex">
      {links.map((l) => (
        <li><a href={l.href} class="text-sm font-medium text-muted transition hover:text-fg">{l.label}</a></li>
      ))}
    </ul>

    <!-- download cta -->
    <a
      href={DOWNLOAD_PAGE}
      class="inline-flex items-center gap-2 rounded-full bg-neon px-5 py-2.5 text-sm font-bold text-white transition hover:brightness-105"
    >
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Download
    </a>
  </nav>
</header>

<!-- mobile sticky bottom download bar -->
<div class="fixed inset-x-0 bottom-0 z-50 border-t border-line bg-ink/95 px-4 py-3 backdrop-blur-md lg:hidden">
  <a
    href={DOWNLOAD_PAGE}
    class="glow-neon flex w-full items-center justify-center gap-2 rounded-full bg-neon px-6 py-3.5 text-base font-bold text-white"
  >
    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
    Download NetMirror TV APK · 49 MB
  </a>
</div>
