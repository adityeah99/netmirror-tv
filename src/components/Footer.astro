---
// Footer.astro — dark footer with disclaimer + links + trust badges
const cols = [
  {
    title: "Product",
    links: [
      { href: "#features", label: "Features" },
      { href: "#download", label: "Download" },
      { href: "#review", label: "30-Day Review" },
      { href: "#compare", label: "Compare" },
    ],
  },
  {
    title: "Guides",
    links: [
      { href: "#install", label: "Install Guide" },
      { href: "#download", label: "Firestick Setup" },
      { href: "#troubleshooting", label: "Troubleshooting" },
      { href: "#tips", label: "Pro Tips" },
    ],
  },
  {
    title: "Legal",
    links: [
      { href: "#", label: "Privacy Policy" },
      { href: "#", label: "Terms of Use" },
      { href: "/contact", label: "Contact" },
      { href: "#faq", label: "FAQ" },
    ],
  },
];
const badges = ["VirusTotal Verified", "SHA-256 Published", "No Signup", "49 MB APK"];
const year = 2026;
---

<footer class="bg-[#0f172a] text-slate-300">
  <div class="mx-auto max-w-7xl px-5 py-14 sm:px-8">
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-[1.4fr_1fr_1fr_1fr]">
      <!-- brand -->
      <div>
        <div class="flex items-center gap-2">
          <img src="/logo.png" alt="NetMirror TV logo" class="h-9 w-9 rounded-lg object-cover" />
          <span class="text-lg font-extrabold tracking-tight text-white">NetMirror <span class="text-neon">TV</span></span>
        </div>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-slate-400">
          Stream 500K+ movies, web series & live TV on Fire TV Stick, Android TV and Smart TV —
          free, no signup.
        </p>
        <!-- telegram -->
        <a href="https://t.me/netflix_mirror_apk" target="_blank" rel="noopener noreferrer" class="mt-5 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-semibold text-white transition hover:bg-white/10">
          <svg class="h-4 w-4 text-[#229ED9]" viewBox="0 0 24 24" fill="currentColor"><path d="M21.94 4.6 18.9 19.05c-.23 1.01-.83 1.26-1.68.79l-4.64-3.42-2.24 2.16c-.25.25-.46.46-.93.46l.33-4.73 8.6-7.77c.37-.33-.08-.52-.58-.19L7.43 13.4l-4.58-1.43c-1-.31-1.01-1 .21-1.48l17.9-6.9c.83-.31 1.56.19 1.28 1.01z"/></svg>
          Join our Telegram
        </a>
        <!-- trust badges -->
        <ul class="mt-5 flex flex-wrap gap-2">
          {badges.map((b) => (
            <li class="flex items-center gap-1.5 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-medium text-slate-300">
              <svg class="h-3.5 w-3.5 text-neon-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {b}
            </li>
          ))}
        </ul>
      </div>

      <!-- link columns -->
      {cols.map((c) => (
        <div>
          <h3 class="text-sm font-bold uppercase tracking-wide text-white">{c.title}</h3>
          <ul class="mt-4 space-y-2.5">
            {c.links.map((l) => (
              <li>
                <a
                  href={l.href}
                  target={l.href.startsWith("http") ? "_blank" : undefined}
                  rel={l.href.startsWith("http") ? "noopener noreferrer" : undefined}
                  class="text-sm text-slate-400 transition hover:text-white"
                >{l.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- disclaimer -->
    <div class="mt-12 border-t border-white/10 pt-8">
      <p class="text-xs leading-relaxed text-slate-500">
        <strong class="text-slate-400">Disclaimer:</strong> NetMirror TV is not affiliated with,
        endorsed by, or sponsored by Netflix, Amazon Prime Video, Disney+, JioHotstar, or any other
        streaming service. All product names, logos and brands are property of their respective
        owners and are used for identification purposes only. This website provides information about
        a third-party application. Users are responsible for complying with the laws of their
        country. For full privacy and security, using a VPN while streaming is recommended.
      </p>
      <div class="mt-6 flex flex-col items-start justify-between gap-2 sm:flex-row sm:items-center">
        <p class="text-xs text-slate-500">© {year} NetMirror TV · v2.0.8 · All rights reserved.</p>
        <p class="text-xs text-slate-500">Made for the big screen.</p>
      </div>
    </div>
  </div>

  <!-- spacer so mobile bottom bar never hides footer content -->
  <div class="h-20 lg:hidden"></div>
</footer>
