---
// PowerFeatures.astro — Casting, Offline downloads, Picture-in-Picture
const features = [
  {
    icon: "📡",
    title: "Casting & Chromecast",
    body: "Found something on your phone? Cast it straight to any Chromecast or Google TV. Start watching on mobile and finish on the big screen without missing a beat.",
  },
  {
    icon: "⬇️",
    title: "Offline Downloads",
    body: "Save movies and shows to your TV's storage and watch them later with no internet — ideal for power cuts, travel or a slow connection.",
  },
  {
    icon: "🪟",
    title: "Picture-in-Picture",
    body: "Pop the video into a floating window and keep browsing the catalogue or switching apps while it keeps playing.",
  },
];
---

<section id="power-features" class="bg-ink-2 py-20 sm:py-24">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <p class="text-sm font-semibold uppercase tracking-widest text-neon">More ways to watch</p>
    <h2 class="mt-3 text-3xl font-extrabold tracking-tight sm:text-4xl">
      Cast, download & watch your way
    </h2>

    <div class="mt-12 grid grid-cols-1 gap-5 sm:grid-cols-3">
      {features.map((f) => (
        <div class="rounded-2xl border border-line bg-ink p-6 transition hover:border-neon/50">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-ink-3 text-2xl">{f.icon}</div>
          <h3 class="mt-5 text-lg font-bold text-fg">{f.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted">{f.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
