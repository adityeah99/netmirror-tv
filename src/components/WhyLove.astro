---
// WhyLove.astro — Why Users Love NetMirror TV
const reasons = [
  "True cinematic experience on the big screen",
  "Super easy remote navigation",
  "Smoother playback & better sound quality",
  "Perfect for family movie nights",
  "No monthly subscriptions needed",
  "Regular content updates",
];
---

<section id="why" class="bg-ink py-20 sm:py-24">
  <div class="mx-auto max-w-5xl px-5 sm:px-8">
    <p class="text-sm font-semibold uppercase tracking-widest text-neon">Why NetMirror TV</p>
    <h2 class="mt-3 max-w-2xl text-3xl font-extrabold tracking-tight sm:text-4xl">
      Why Users Love NetMirror TV
    </h2>

    <ul class="mt-12 grid grid-cols-1 gap-4 sm:grid-cols-2">
      {reasons.map((r) => (
        <li class="flex items-center gap-4 rounded-2xl border border-line bg-ink-2 px-5 py-5 transition hover:border-neon/50">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-neon/15">
            <svg class="h-5 w-5 text-neon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </span>
          <span class="text-base font-medium text-fg">{r}</span>
        </li>
      ))}
    </ul>
  </div>
</section>
