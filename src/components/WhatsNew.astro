---
import { DOWNLOAD_PAGE } from "../config";
// WhatsNew.astro — changelog for the latest version
const VERSION = "2.0.8";
const DATE = "6 June 2026";

const catStyle = {
  New: "bg-neon-3/15 text-neon-3",
  Added: "bg-neon-3/15 text-neon-3",
  Improved: "bg-blue-500/15 text-blue-600",
  Changed: "bg-amber-400/20 text-amber-600",
  Removed: "bg-neon/10 text-neon",
  Redesigned: "bg-purple-500/15 text-purple-600",
  Expanded: "bg-teal-500/15 text-teal-600",
};

const changes = [
  { cat: "New", title: "Server 2 (Beta): a second source", body: "A new backup server. If a title won't play on Server 1, switch to Beta Server 2 from the Watch screen to unlock more movies and shows, extra audio tracks and wider subtitles." },
  { cat: "Redesigned", title: "A fresh, cleaner interface", body: "The whole app was redesigned to be simpler and faster to move around — chips, rails and a single search bar up front." },
  { cat: "Expanded", title: "Eight services, not two", body: "It used to carry only Netflix and Prime Video. Now eight OTT platforms — JioHotstar, Apple TV+, Sony LIV, Zee5, MX Player and Crunchyroll too — sit in one library." },
  { cat: "Added", title: "Anime is here", body: "A dedicated Anime section joins the catalogue — simulcast episodes, classics and full movie collections." },
  { cat: "New", title: "Picture-in-Picture mode", body: "Pop the video into a floating window and keep browsing the catalogue while it plays." },
  { cat: "Changed", title: "Sign-in is now optional", body: "Signing in used to be required. Now you watch the whole library as a guest — sign in only if you want your list to sync." },
  { cat: "Removed", title: "No more ads", body: "The app now runs with zero ads — no launch ad, no mid-rolls, no banners over the player." },
  { cat: "Expanded", title: "A much bigger library", body: "The catalogue has grown well beyond what it carried before, across every genre and language." },
  { cat: "Improved", title: "One search across every platform", body: "Search a movie or show once and it looks across all eight services at the same time — no switching platforms." },
];
---

<section id="whats-new" class="bg-ink py-20 sm:py-24">
  <div class="mx-auto max-w-3xl px-5 sm:px-8">
    <p class="text-sm font-semibold uppercase tracking-widest text-neon">What's New</p>
    <h2 class="mt-3 text-3xl font-extrabold tracking-tight sm:text-4xl">
      What's new in NetMirror TV
    </h2>

    <!-- version header -->
    <div class="mt-8 flex flex-wrap items-center gap-3 rounded-2xl border border-line bg-ink-2 px-5 py-4">
      <span class="text-lg font-extrabold text-fg">Version {VERSION}</span>
      <span class="rounded-full bg-neon-3/15 px-2.5 py-1 text-xs font-bold uppercase tracking-wide text-neon-3">Latest</span>
      <span class="ml-auto text-sm text-muted">{DATE}</span>
    </div>

    <!-- changes -->
    <ul class="mt-6 space-y-5">
      {changes.map((c) => (
        <li class="flex flex-col gap-2 border-l-2 border-line pl-5 sm:flex-row sm:gap-5 sm:pl-0 sm:border-l-0">
          <span class={`inline-flex h-fit w-fit shrink-0 rounded-full px-3 py-1 text-xs font-bold uppercase tracking-wide sm:w-24 sm:justify-center ${catStyle[c.cat]}`}>{c.cat}</span>
          <div>
            <h3 class="text-base font-bold text-fg">{c.title}</h3>
            <p class="mt-1 text-sm leading-relaxed text-muted">{c.body}</p>
          </div>
        </li>
      ))}
    </ul>

    <a href={DOWNLOAD_PAGE} class="mt-10 inline-flex items-center gap-2 rounded-full bg-neon px-6 py-3 text-sm font-bold text-white transition hover:brightness-105">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Get version {VERSION}
    </a>
  </div>
</section>
