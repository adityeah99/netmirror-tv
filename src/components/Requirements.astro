---
// Requirements.astro — System Requirements
const specs = [
  {
    label: "Minimum",
    tag: "To get started",
    accent: false,
    items: [
      "Android TV 7.0 or above",
      "2 GB RAM",
      "Stable internet connection",
    ],
  },
  {
    label: "Recommended",
    tag: "For 4K streaming",
    accent: true,
    items: [
      "Android TV 11 or above",
      "4 GB RAM",
      "High-speed broadband connection",
    ],
  },
];
---

<section id="requirements" class="bg-ink py-20 sm:py-24">
  <div class="mx-auto max-w-5xl px-5 sm:px-8">
    <p class="text-sm font-semibold uppercase tracking-widest text-neon">System Requirements</p>
    <h2 class="mt-3 text-3xl font-extrabold tracking-tight sm:text-4xl">
      System Requirements
    </h2>

    <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-2">
      {specs.map((s) => (
        <div class={`rounded-2xl border p-6 sm:p-8 ${s.accent ? "border-neon/40 bg-neon/5" : "border-line bg-ink-2"}`}>
          <div class="flex items-center justify-between">
            <h3 class="text-xl font-bold text-fg">{s.label}</h3>
            <span class={`rounded-full px-3 py-1 text-xs font-semibold ${s.accent ? "bg-neon text-white" : "bg-ink-3 text-muted"}`}>
              {s.tag}
            </span>
          </div>
          <ul class="mt-6 space-y-4">
            {s.items.map((item) => (
              <li class="flex items-center gap-3 text-base text-fg/90">
                <svg class={`h-5 w-5 shrink-0 ${s.accent ? "text-neon" : "text-muted"}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
