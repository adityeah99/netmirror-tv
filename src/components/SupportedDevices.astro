---
// SupportedDevices.astro — device compatibility grid
const devices = [
  { logo: "/brands/amazon.svg", name: "Fire TV Stick", note: "All Lite / 4K / Max" },
  { logo: "/brands/amazon.svg", name: "Fire TV Cube", note: "Fire OS 6+" },
  { logo: "/brands/android.svg", name: "Android TV", note: "Android TV 7.0+" },
  { logo: "/brands/googletv.svg", name: "Google TV", note: "incl. Chromecast" },
  { logo: "/brands/xiaomi.svg", name: "Xiaomi / Mi TV", note: "PatchWall & stock" },
  { logo: "/brands/oneplus.svg", name: "OnePlus TV", note: "Oxygen Play" },
  { logo: "/brands/sony.svg", name: "Sony Bravia", note: "Android-based models" },
  { logo: "/brands/tcl.svg", name: "TCL", note: "Android TV builds" },
  { logo: "/brands/nvidia.svg", name: "Nvidia Shield", note: "Android TV Pro" },
];
---

<section id="devices" class="bg-ink-2 py-20 sm:py-24">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <p class="text-sm font-semibold uppercase tracking-widest text-neon">Compatibility</p>
    <h2 class="mt-3 text-3xl font-extrabold tracking-tight sm:text-4xl">
      Works on the TVs you already own
    </h2>
    <p class="mt-4 max-w-2xl text-base leading-relaxed text-muted sm:text-lg">
      If it runs Android TV, Fire OS or Google TV, NetMirror TV runs on it. Here are the most common
      supported devices.
    </p>

    <div class="mt-12 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
      {devices.map((d) => (
        <div class="flex flex-col items-center rounded-2xl border border-line bg-ink p-5 text-center transition hover:border-neon/50">
          <div class="flex h-12 items-center justify-center">
            <img src={d.logo} alt={`${d.name} logo`} loading="lazy" class="h-9 w-auto max-w-[80%] object-contain" />
          </div>
          <h3 class="mt-3 text-sm font-bold text-fg">{d.name}</h3>
          <p class="mt-1 text-xs text-muted">{d.note}</p>
        </div>
      ))}
    </div>

    <p class="mt-8 text-sm text-muted">
      Also works on Chromecast, Mi Box, Hisense, Realme and other Android set-top boxes. If it's an
      <strong class="text-fg">Android-based Smart TV (7.0+)</strong>, it'll almost certainly run —
      just sideload the APK.
    </p>
  </div>
</section>
