---
import Icon from "./Icon.astro";
// CommonIssues.astro — Common Issues & Quick Fixes
const issues = [
  {
    icon: "wifi",
    problem: "Buffering Problems",
    fixes: ["Use faster Wi-Fi", "Switch streaming server", "Lower quality temporarily"],
  },
  {
    icon: "circle-x",
    problem: "App Not Opening",
    fixes: ["Restart TV", "Reinstall app", "Clear cache"],
  },
  {
    icon: "monitor-off",
    problem: "Black Screen",
    fixes: ["Update the app", "Change server", "Check TV compatibility"],
  },
  {
    icon: "gamepad-2",
    problem: "Remote Not Working Properly",
    fixes: ["Update Android TV system", "Restart app", "Re-pair remote"],
  },
];
---

<section id="troubleshooting" class="bg-ink-2 py-20 sm:py-24">
  <div class="mx-auto max-w-5xl px-5 sm:px-8">
    <p class="text-sm font-semibold uppercase tracking-widest text-neon">Troubleshooting</p>
    <h2 class="mt-3 text-3xl font-extrabold tracking-tight sm:text-4xl">
      Common Issues & Quick Fixes
    </h2>
    <p class="mt-4 max-w-2xl text-base leading-relaxed text-muted sm:text-lg">
      Most problems take seconds to fix. Here's what to try first.
    </p>

    <div class="mt-12 grid grid-cols-1 gap-5 sm:grid-cols-2">
      {issues.map((it) => (
        <div class="rounded-2xl border border-line bg-ink p-6 transition hover:border-neon/50">
          <div class="flex items-center gap-3">
            <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-ink-3 text-neon">
              <Icon name={it.icon} class="h-5 w-5" />
            </span>
            <h3 class="text-lg font-bold text-fg">{it.problem}</h3>
          </div>
          <ul class="mt-5 space-y-2.5">
            {it.fixes.map((fix) => (
              <li class="flex items-start gap-2.5 text-sm text-muted">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-neon-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                <span>{fix}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
