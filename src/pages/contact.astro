---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { TELEGRAM_URL } from "../config";

const topics = [
  { icon: "❓", title: "General questions", body: "Not sure how something works or which build to install? Ask away." },
  { icon: "💡", title: "Feedback & suggestions", body: "Got an idea to make NetMirror TV better? We genuinely read every message." },
  { icon: "🐞", title: "Bugs & issues", body: "Something not working right? Tell us your device and what happened." },
  { icon: "⚖️", title: "Content removal", body: "Rights holders can send takedown / removal requests and we'll act on them." },
];
---

<Layout
  title="Contact NetMirror TV — Support, Feedback & Removal Requests"
  description="Get in touch with the NetMirror TV team for questions, feedback, bug reports or content removal requests. We're most active on Telegram."
>
  <Navbar />
  <main id="top">
    <section class="relative overflow-hidden bg-ink py-16 sm:py-24">
      <div aria-hidden="true" class="pointer-events-none absolute inset-x-0 -top-40 h-[34rem] bg-[radial-gradient(60%_60%_at_50%_0%,rgba(245,53,74,0.10)_0%,rgba(245,53,74,0)_70%)]"></div>

      <div class="relative mx-auto max-w-3xl px-5 sm:px-8">
        <p class="text-sm font-semibold uppercase tracking-widest text-neon">Contact</p>
        <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-fg sm:text-5xl">
          Contact Us
        </h1>
        <p class="mt-5 max-w-2xl text-lg leading-relaxed text-muted">
          Got a question, some feedback, or a content removal request? We'd love to hear from you.
          The quickest way to reach the NetMirror TV team is through our
          <strong class="text-fg">Telegram channel</strong> — we're most active there and usually
          reply fast. We don't offer email support right now, so Telegram is the best way to get in touch.
        </p>

        <!-- topics -->
        <div class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-2">
          {topics.map((t) => (
            <div class="rounded-2xl border border-line bg-ink-2 p-5">
              <div class="text-2xl">{t.icon}</div>
              <h3 class="mt-3 text-base font-bold text-fg">{t.title}</h3>
              <p class="mt-1 text-sm leading-relaxed text-muted">{t.body}</p>
            </div>
          ))}
        </div>

        <!-- telegram CTA -->
        <div class="mt-10 flex flex-col items-start justify-between gap-4 rounded-2xl border border-line bg-ink-2 p-6 sm:flex-row sm:items-center sm:p-8">
          <div>
            <h2 class="text-lg font-bold text-fg">Message us on Telegram</h2>
            <p class="mt-1 text-sm text-muted">Tap below, send your message, and we'll get back to you.</p>
          </div>
          <a
            href={TELEGRAM_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex shrink-0 items-center gap-2 rounded-full bg-neon px-6 py-3 text-sm font-bold text-white transition hover:brightness-105"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M21.94 4.6 18.9 19.05c-.23 1.01-.83 1.26-1.68.79l-4.64-3.42-2.24 2.16c-.25.25-.46.46-.93.46l.33-4.73 8.6-7.77c.37-.33-.08-.52-.58-.19L7.43 13.4l-4.58-1.43c-1-.31-1.01-1 .21-1.48l17.9-6.9c.83-.31 1.56.19 1.28 1.01z"/></svg>
            Open Telegram
          </a>
        </div>

        <a href="/" class="mt-8 inline-block text-sm font-medium text-muted transition hover:text-fg">← Back to home</a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
